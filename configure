#!/bin/bash
#
# configure - CMake包装脚本，提供Autotools风格的配置接口
#

set -e

# 默认配置
BUILD_TYPE="Release"
BUILD_DIR="build"
INSTALL_PREFIX="/usr/local"
BUILD_TESTS=ON
BUILD_APPS=OFF
BUILD_EXAMPLES=OFF
CMAKE_OPTIONS=""

# 帮助信息
show_help() {
    echo "配置 IPCSharedDataPool 构建环境"
    echo ""
    echo "用法: ./configure [选项]"
    echo ""
    echo "选项:"
    echo "  --help, -h              显示此帮助信息"
    echo "  --prefix=DIR            安装目录 (默认: /usr/local)"
    echo "  --builddir=DIR          构建目录 (默认: build)"
    echo "  --enable-debug          启用调试构建"
    echo "  --enable-tests          构建测试 (默认: 启用)"
    echo "  --disable-tests         禁用测试构建"
    echo "  --enable-apps           构建应用程序 (默认: 禁用)"
    echo "  --disable-apps          禁用应用程序构建"
    echo "  --enable-examples       构建示例 (默认: 禁用)"
    echo "  --disable-examples      禁用示例构建"
    echo "  --with-qt5=DIR          Qt5安装路径"
    echo ""
    echo "示例:"
    echo "  ./configure"
    echo "  ./configure --prefix=/usr --enable-debug"
    echo "  ./configure --enable-apps --with-qt5=/opt/Qt5.15.8"
    exit 0
}

# 解析参数
for arg in "$@"; do
    case $arg in
        --help|-h)
            show_help
            ;;
        --prefix=*)
            INSTALL_PREFIX="${arg#*=}"
            CMAKE_OPTIONS="$CMAKE_OPTIONS -DCMAKE_INSTALL_PREFIX=$INSTALL_PREFIX"
            ;;
        --builddir=*)
            BUILD_DIR="${arg#*=}"
            ;;
        --enable-debug)
            BUILD_TYPE="Debug"
            ;;
        --enable-tests)
            BUILD_TESTS=ON
            ;;
        --disable-tests)
            BUILD_TESTS=OFF
            ;;
        --enable-apps)
            BUILD_APPS=ON
            ;;
        --disable-apps)
            BUILD_APPS=OFF
            ;;
        --enable-examples)
            BUILD_EXAMPLES=ON
            ;;
        --disable-examples)
            BUILD_EXAMPLES=OFF
            ;;
        --with-qt5=*)
            QT5_DIR="${arg#*=}"
            export Qt5_DIR="$QT5_DIR/lib/cmake/Qt5"
            CMAKE_OPTIONS="$CMAKE_OPTIONS -DCMAKE_PREFIX_PATH=$QT5_DIR/lib/cmake/Qt5"
            ;;
        *)
            echo "警告: 未知选项 '$arg'"
            ;;
    esac
done

# 检查依赖
echo "检查依赖..."

# 检查CMake
if ! command -v cmake &> /dev/null; then
    echo "错误: 未找到cmake，请先安装cmake"
    exit 1
fi

CMAKE_VERSION=$(cmake --version | head -n1 | cut -d' ' -f3)
echo "  - cmake: $CMAKE_VERSION"

# 检查编译器
if command -v g++ &> /dev/null; then
    GCC_VERSION=$(g++ --version | head -n1)
    echo "  - g++: $GCC_VERSION"
elif command -v clang++ &> /dev/null; then
    CLANG_VERSION=$(clang++ --version | head -n1)
    echo "  - clang++: $CLANG_VERSION"
else
    echo "错误: 未找到C++编译器"
    exit 1
fi

# 检查Qt5 (仅在需要时)
if [ "$BUILD_TESTS" = "ON" ] || [ "$BUILD_APPS" = "ON" ]; then
    if ! pkg-config --exists Qt5Core 2>/dev/null; then
        if [ -z "$Qt5_DIR" ]; then
            echo "警告: 未找到Qt5，部分测试和应用将无法构建"
            echo "       使用 --with-qt5=/path/to/qt5 指定Qt5路径"
        fi
    else
        QT_VERSION=$(pkg-config --modversion Qt5Core)
        echo "  - Qt5: $QT_VERSION"
    fi
fi

echo ""
echo "配置摘要:"
echo "  构建类型:     $BUILD_TYPE"
echo "  构建目录:     $BUILD_DIR"
echo "  安装目录:     $INSTALL_PREFIX"
echo "  构建测试:     $BUILD_TESTS"
echo "  构建应用:     $BUILD_APPS"
echo "  构建示例:     $BUILD_EXAMPLES"
echo ""

# 创建构建目录
mkdir -p "$BUILD_DIR"

# 运行CMake配置
echo "运行CMake配置..."
cmake -B "$BUILD_DIR" \
    -DCMAKE_BUILD_TYPE="$BUILD_TYPE" \
    -DBUILD_TESTS="$BUILD_TESTS" \
    -DBUILD_APPS="$BUILD_APPS" \
    -DBUILD_EXAMPLES="$BUILD_EXAMPLES" \
    $CMAKE_OPTIONS \
    .

# 创建包装Makefile
cat > Makefile << 'MAKEFILE_EOF'
# Makefile包装器 - 将命令转发到CMake构建系统
BUILD_DIR ?= build

.PHONY: all clean check test install uninstall dist distcheck configure help

all: configure
	@echo "构建项目..."
	cmake --build $(BUILD_DIR) -- -j$$(nproc 2>/dev/null || echo 4)

configure:
	@if [ ! -f $(BUILD_DIR)/CMakeCache.txt ]; then \
		echo "请先运行 ./configure"; \
		exit 1; \
	fi

clean:
	@echo "清理构建文件..."
	cmake --build $(BUILD_DIR) --target clean

check test: configure
	@echo "运行测试..."
	cd $(BUILD_DIR) && ctest --output-on-failure -j$$(nproc 2>/dev/null || echo 4)

install: configure
	@echo "安装到系统..."
	cmake --install $(BUILD_DIR)

uninstall:
	@echo "卸载..."
	@if [ -f $(BUILD_DIR)/install_manifest.txt ]; then \
		xargs rm -f < $(BUILD_DIR)/install_manifest.txt; \
		echo "卸载完成"; \
	else \
		echo "未找到安装清单，无法卸载"; \
		exit 1; \
	fi

dist:
	@echo "创建源码分发包..."
	@VERSION=$$(grep -m1 'project(' CMakeLists.txt | sed 's/.*VERSION \([0-9.]*\).*/\1/'); \
	ARCHIVE="IPCSharedDataPool-$$VERSION.tar.gz"; \
	tar --transform "s,^,IPCSharedDataPool-$$VERSION/," \
		--exclude='.git' \
		--exclude='build' \
		--exclude='*.tar.gz' \
		--exclude='examples' \
		-czf "$$ARCHIVE" \
		. && \
	echo "已创建: $$ARCHIVE"

distcheck: dist
	@echo "验证分发包..."
	@ARCHIVE=$$(ls -t IPCSharedDataPool-*.tar.gz | head -1); \
	DIR=$${ARCHIVE%.tar.gz}; \
	echo "解压 $$ARCHIVE..."; \
	tar -xzf "$$ARCHIVE"; \
	echo "配置..."; \
	cd "$$DIR" && ./configure --disable-tests; \
	echo "构建..."; \
	$(MAKE); \
	echo "验证完成"; \
	cd .. && rm -rf "$$DIR"

help:
	@echo "可用目标:"
	@echo "  all         - 构建项目 (默认)"
	@echo "  clean       - 清理构建文件"
	@echo "  check       - 运行测试"
	@echo "  test        - 运行测试 (同check)"
	@echo "  install     - 安装到系统"
	@echo "  uninstall   - 卸载"
	@echo "  dist        - 创建源码分发包"
	@echo "  distcheck   - 验证分发包"
	@echo "  configure   - 检查是否已配置"
	@echo ""
	@echo "使用方法:"
	@echo "  1. ./configure [选项]"
	@echo "  2. make"
	@echo "  3. make check (可选)"
	@echo "  4. sudo make install"
MAKEFILE_EOF

echo ""
echo "配置完成！"
echo ""
echo "接下来请运行:"
echo "  make          # 构建项目"
echo "  make check    # 运行测试"
echo "  make install  # 安装 (需要root权限)"
